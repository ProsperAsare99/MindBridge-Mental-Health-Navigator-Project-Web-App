generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id String @id @default(uuid())

  // Authentication
  email       String  @unique
  password    String?
  googleId    String? @unique
  isVerified  Boolean @default(false)
  isAnonymous Boolean @default(false)

  // Basic Profile
  displayName   String? // From Mongoose: displayName
  university    String? // From Mongoose: university
  academicLevel Int? // From Mongoose: academicLevel (100, 200, 300, 400)
  program       String? // From Mongoose: program
  image         String?

  // Communication Preferences
  language               String @default("english") // english, twi, ga, ewe
  notificationPreference String @default("daily") // daily, weekly, only_when_needed, none
  preferredCheckInTime   String @default("morning") // morning, afternoon, evening, night

  // Mental Health Context
  concerns     String[] @default([]) // academic_stress, anxiety, etc.
  supportLevel String   @default("somewhat") // alone, somewhat, strong
  riskLevel    String   @default("LOW") // LOW, MODERATE, HIGH, CRITICAL

  // Personalization
  copingStyles       String[] @default([]) // exercise, journal, etc.
  faithLevel         String   @default("somewhat_important") // very_important, etc.
  approachPreference String   @default("holistic") // clinical, holistic, cultural, mixed
  goals              String[] @default([]) // reduce_stress, improve_mood, etc.

  // Complex Data (JSONB)
  stressors           Json? // exams, assignments, etc. (1-5 scale)
  trackingPreferences Json? // mood, sleep, etc. (Boolean map)
  emergencyContacts   Json? // Name, Relationship, Phone

  // Baseline & Metrics
  baseline           Json? // mood, joinDate
  moodCheckInsCount  Int       @default(0)
  conversationsCount Int       @default(0)
  lastActive         DateTime?

  // Onboarding Status (Legacy/System)
  onboardingStep      Int     @default(1)
  onboardingCompleted Boolean @default(false)
  verificationToken   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessments  Assessment[]
  moods        Mood[]
  chatMessages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  role      String // 'user' or 'assistant'
  createdAt DateTime @default(now())
}

model Assessment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  score     Int
  severity  String
  createdAt DateTime @default(now())
}

model Mood {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value          Int // 1-5 (Awful to Great)
  note           String?
  sentimentScore Float?
  sentimentLabel String?
  crisisFlag     Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model AcademicEvent {
  id         String   @id @default(uuid())
  title      String
  type       String // 'exam', 'deadline', 'holiday'
  date       DateTime
  importance Int      @default(1) // 1-5
  createdAt  DateTime @default(now())
}
